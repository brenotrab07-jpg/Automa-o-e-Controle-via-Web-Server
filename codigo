void setup() {
  Serial.begin(115200);
  
  pinMode(PIN_SERVO, OUTPUT);
  pinMode(PIN_LED1, OUTPUT);
  pinMode(PIN_LED2, OUTPUT);
  digitalWrite(PIN_LED1, LOW);
  digitalWrite(PIN_LED2, LOW);

  // Inicialização do Hardware Timer (Core 3.x)
  timer = timerBegin(1000000); 
  timerAttachInterrupt(timer, &onTimer); 
  timerAlarm(timer, 10, true, 0); 

  Serial.print("Conectando ao Wi-Fi");
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nConectado!");
  Serial.print("IP para acesso: ");
  Serial.println(WiFi.localIP());

  // Rotas do WebServer Nativo
  server.on("/", HTTP_GET, []() {
    server.send(200, "text/html", index_html);
  });

  server.on("/led", HTTP_GET, []() {
    if (server.hasArg("id") && server.hasArg("state")) {
      String id = server.arg("id");
      String state = server.arg("state");
      
      int pin = (id == "1") ? PIN_LED1 : PIN_LED2;
      digitalWrite(pin, state == "1" ? HIGH : LOW);
    }
    server.send(200, "text/plain", "OK");
  });

  server.on("/servo", HTTP_GET, []() {
    if (server.hasArg("angle")) {
      int angle = server.arg("angle").toInt();
      setServoAngle(angle);
    }
    server.send(200, "text/plain", "OK");
  });

  server.begin();
}

void loop() {
  // A biblioteca nativa exige que o cliente seja "escutado" constantemente no loop
  server.handleClient();
  delay(2); // Pequeno atraso para manter a estabilidade da simulação e do Wi-Fi
}
