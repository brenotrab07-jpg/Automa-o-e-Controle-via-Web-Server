#include <WiFi.h>
#include <WebServer.h> // <-- Biblioteca Nativa (sem dependências externas)

// Definições de Pinos
const int PIN_SERVO = 13; // Restrição: Sem PWM nativo neste projeto
const int PIN_LED1 = 12;
const int PIN_LED2 = 14;

// Credenciais de Wi-Fi para o simulador Wokwi
const char* ssid = "Wokwi-GUEST";
const char* password = "";

// Instância do Servidor Web nativo na porta 80
WebServer server(80);

// ====================================================================
// SOLUÇÃO DE ENGENHARIA: PWM via Software (Timer/Interrupção)
// Compatível com ESP32 Core 3.x
// ====================================================================
hw_timer_t * timer = NULL;
volatile uint32_t counter = 0;
volatile uint32_t pulseWidth = 1500; // Pulso inicial de 1.5ms (90 graus)
portMUX_TYPE timerMux = portMUX_INITIALIZER_UNLOCKED;

// Interrupção disparada a cada 10 microsegundos
void IRAM_ATTR onTimer() {
  portENTER_CRITICAL_ISR(&timerMux);
  counter += 10;
  
  if (counter >= 20000) {
    counter = 0;
    digitalWrite(PIN_SERVO, HIGH);
  } 
  else if (counter >= pulseWidth) {
    digitalWrite(PIN_SERVO, LOW);
  }
  portEXIT_CRITICAL_ISR(&timerMux);
}

// Função para converter graus (0-180) em largura de pulso (us)
void setServoAngle(int angle) {
  if(angle < 0) angle = 0;
  if(angle > 180) angle = 180;
  uint32_t newPulse = map(angle, 0, 180, 500, 2400);
  
  portENTER_CRITICAL(&timerMux);
  pulseWidth = newPulse;
  portEXIT_CRITICAL(&timerMux);
}
// ====================================================================

// Interface HTML armazenada na memória flash (PROGMEM)
const char index_html[] PROGMEM = R"rawliteral(
